# Copiez ce fichier en .env et remplissez les vraies valeurs (jamais commit .env lui-même).
# Utilisé par src/lib/waitlist.ts pour envoyer les inscriptions de la liste d'attente vers Notion.

# Settings → Connections → Developer connections → créez une intégration, copiez son "Internal Integration Secret".
NOTION_TOKEN=

# L'ID de la base Notion (dans son URL : notion.so/xxxxx?v=... → xxxxx est le NOTION_DATABASE_ID).
# La base doit avoir une propriété "Email" comme titre, et être partagée avec l'intégration
# (⋯ en haut à droite de la base → Connexions → ajouter l'intégration).
NOTION_DATABASE_ID=
